# Auto detect text files and perform LF normalization
* text=auto
*.c text eol=crlf
*.cc text eol=crlf
*.cpp text eol=crlf
*.cxx text eol=crlf
*.h text eol=crlf
*.hh text eol=crlf
*.hpp text eol=crlf
*.hxx text eol=crlf
*.ixx text eol=crlf
*.inl text eol=crlf
*.hlsl text eol=crlf
*.usf text eol=crlf
*.ush text eol=crlf
*.obj filter=lfs diff=lfs merge=lfs -text
